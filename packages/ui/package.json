{
  "name": "@repo/ui",
  "version": "0.0.0",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src/styles.css"
  ],
  "license": "MIT",
  "exports": {
    "./button": "./src/components/button.tsx",
    "./section": "./src/components/section.tsx",
    "./card": "./src/components/card.tsx",
    "./gradient": "./src/components/gradient.tsx",
    "./styles.css": "./dist/index.css",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && pnpm run build:styles && pnpm run build:components",
    "build:styles": "mkdir -p dist && tailwindcss -i ./src/styles.css -o ./dist/index.css --minify",
    "build:components": "tsc",
    "check-types": "tsc --noEmit",
    "dev:components": "tsc --watch",
    "dev:styles": "mkdir -p dist && tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
    "lint": "eslint src --max-warnings 0",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@tailwindcss/cli": "^4.1.17",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/react": "^19.2.7",
    "eslint": "^9.39.1",
    "storybook": "^8.6.14",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1"
  }
}